  "keyFeatures": [
    "AI-generated personalized 4-week learning plans based on Moodle academic data",
    "Soft skills assessment (autonomy, time management, communication, teamwork)",
    "Focus cards system with 6 prioritized learning cards (2 high, 2 medium, 2 low)",
    "AI chat assistant (IAtrainer) for real-time learning support",
    "Team Leader analytics dashboard with at-risk student detection",
    "AI-generated executive reports for TL (per coder, clan, or cohort)",
    "Activity progress tracking with evidence submission",
    "Risk flagging system with low/medium/high severity levels",
    "GitHub and Google OAuth social authentication",
    "Hybrid architecture: Node.js API Gateway + Python/FastAPI AI microservice"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
